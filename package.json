{
  "name": "depo-stok-new",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "lint": "next lint",
    "lint:backend": "sh -c 'if [ -x ./node_modules/.bin/eslint ]; then ./node_modules/.bin/eslint src/app/api src/modules src/shared middleware.ts; else echo \"eslint bulunamadı. npm i -D eslint @typescript-eslint/parser @typescript-eslint/eslint-plugin\"; exit 1; fi'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "quality:backend": "node scripts/check-backend-quality.mjs",
    "quality:backend:strict": "npm run typecheck && npm run quality:backend",
    "codehealth": "npx --yes codehealth . --next --ignore \"node_modules/**\" --ignore \".next/**\" --ignore \"dist/**\"",
    "codehealth:watch": "npx --yes codehealth . --next --watch --ignore \"node_modules/**\" --ignore \".next/**\" --ignore \"dist/**\"",
    "codehealth:ai": "npx --yes codehealth . --next --ai-prompt --ignore \"node_modules/**\" --ignore \".next/**\" --ignore \"dist/**\""
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "argon2": "^0.41.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "next": "^15.0.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.27",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
