NODE_ENV=development
APP_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_SSL=true
SESSION_COOKIE_NAME=depo_session
SESSION_COOKIE_SECURE=false
SESSION_IDLE_TIMEOUT_HOURS=8
SESSION_SLIDING_WINDOW_MINUTES=15
SESSION_CACHE_TTL_MS=10000
NEXT_PUBLIC_CLIENT_POLL_INTERVAL_MS=15000
NEXT_PUBLIC_PRODUCTION_ORDERS_POLL_INTERVAL_MS=5000
API_READ_CACHE_TTL_MS=2000
LOG_NOISY_POLLING_ENDPOINTS=false
